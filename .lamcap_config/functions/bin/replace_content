#!/usr/bin/env python3
import sys
import json
import os

def main():
    if len(sys.argv) < 2:
        print("Error: Missing JSON input.")
        sys.exit(1)

    json_input = json.loads(sys.argv[1])
    path = json_input.get("path")
    pattern = json_input.get("pattern")
    replacement = json_input.get("replacement")

    if not path or pattern is None or replacement is None:
        print("Error: Missing required fields (path, pattern, replacement).")
        sys.exit(1)

    if not os.path.exists(path):
        print(f"Error: File not found: {path}")
        sys.exit(1)

    with open(path, 'r') as f:
        content = f.read()

    if pattern not in content:
        print(f"Error: Pattern not found in {path}")
        sys.exit(1)

    new_content = content.replace(pattern, replacement)

    with open(path, 'w') as f:
        f.write(new_content)

    print(f"Successfully replaced content in {path}")

if __name__ == "__main__":
    main()
